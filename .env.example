# KABANEK Backend - Konfiguracja (PostgreSQL)

# Port serwera (Railway automatycznie ustawia)
PORT=3000

# CORS - dozwolone domeny (lub * dla wszystkich)
# Przykłady:
# CORS_ORIGIN=http://localhost:8080
# CORS_ORIGIN=https://kabanek.example.com
# CORS_ORIGIN=*
CORS_ORIGIN=*

# Środowisko (development lub production)
NODE_ENV=development

# PostgreSQL Database URL (Railway automatycznie ustawia to dla Ciebie!)
# Format: postgresql://user:password@host:port/database
# Przykład lokalny:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/kabanek
DATABASE_URL=postgresql://user:password@localhost:5432/kabanek
